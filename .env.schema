# This env file uses @env-spec — see https://varlock.dev/env-spec
#
# @defaultRequired=infer @defaultSensitive=false
# @generateTypes(lang=ts, path=env.d.ts)
# ----------

# URL of the backend HTTP server the front-end consumes.
# @required @type=url
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

# Active l'envoi du header X-CSRF-Token sur les requêtes mutantes.
# Requiert un backend qui expose GET /csrf-token et valide le header.
# @type=boolean
NEXT_PUBLIC_CSRF_ENABLED=false
